# HolexSS Keysystem 2026 — Environment Variables
# Copy this file to `.env` for local development.
# On Railway, set these in the project's Variables tab.

# ── Server ──────────────────────────────────────────────
# Railway sets PORT automatically. For local dev:
PORT=3000

# ── Key Generation ─────────────────────────────────────
# Prefix applied to every generated key. Default: HolexSS-
KEY_PREFIX=HolexSS-

# ── Work.ink Integration ───────────────────────────────
# Your Work.ink slug (used in /Auth/workink response metadata).
# The actual link used on the frontend is set in index.html → CONFIG.workInkLink.
WORKINK_SLUG=YOUR_SLUG_HERE

# ── Security ───────────────────────────────────────────
# Bearer token required to call DELETE /Auth/revoke.
# Leave empty in dev to disable auth. Set in production!
ADMIN_TOKEN=

# ── CORS ───────────────────────────────────────────────
# Comma-separated list of allowed origins, or "*" for any.
CORS_ORIGIN=*

# ── Railway (auto-set by Railway, no need to set locally) ──
# RAILWAY_ENVIRONMENT=production
